# ProphetHacks 2026 — environment template.
# Copy to `.env` and fill in your own credentials before running `./run.sh`
# or any of the scripts in scripts/.

# -- Snowflake ---------------------------------------------------------------
# Account locator (e.g. ABC12345). Found in Snowsight: bottom-left avatar -> account.
SNOWFLAKE_ACCOUNT=

# Login user.
SNOWFLAKE_USER=

# *Either* a programmatic access token (preferred — skips MFA prompts each run)
# or a password. Set one. The connector uses whichever is present.
SNOWFLAKE_PAT=
SNOWFLAKE_PASSWORD=

# Optional one-shot 6-digit TOTP if SNOWFLAKE_PASSWORD is set and your account
# requires MFA. Leave blank when using SNOWFLAKE_PAT.
SNOWFLAKE_MFA_PASSCODE=

# Session context. Defaults below mirror the hackathon trial-tier layout;
# adjust to match the warehouse/database/schema/role you have access to.
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=PROPHET_HACK
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=

# -- Wafer.ai ----------------------------------------------------------------
# Bearer key for the OpenAI-compatible chat-completions endpoint. Get it from
# https://app.wafer.ai/models. Base URL is fixed in code (pass.wafer.ai/v1).
WAFER_API_KEY=
WAFER_BASE_URL=https://pass.wafer.ai/v1

# -- Optional fallback -------------------------------------------------------
# Only needed if Wafer rate-limits or returns malformed responses. The agent
# does NOT use this by default.
OPENAI_API_KEY=
